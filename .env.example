# Copy this file to .env and fill in the values:  cp .env.example .env
#
# ── Model / provider ─────────────────────────────────────────────────────────
# The backend calls an OpenAI-compatible vision endpoint, so it works with any
# provider that speaks that API. Set the base URL, the API key, and a
# vision-capable model id for your provider of choice:
#
#   Kimi (Moonshot)   LLM_PROVIDER=kimi
#                     LLM_BASE_URL=https://api.moonshot.ai/v1     (or .cn in China)
#                     LLM_MODEL=kimi-k2.6
#   MiniMax           LLM_PROVIDER=minimax
#                     LLM_BASE_URL=https://api.minimax.io/v1
#                     LLM_MODEL=MiniMax-M3
#   OpenAI            LLM_PROVIDER=openai
#                     LLM_BASE_URL=https://api.openai.com/v1        (or leave blank)
#                     LLM_MODEL=gpt-4o
#   Claude            LLM_PROVIDER=claude
#                     LLM_BASE_URL=https://api.anthropic.com/v1/
#                     LLM_MODEL=claude-opus-4-8
#
# Leave LLM_BASE_URL blank to use OpenAI's default endpoint.
LLM_PROVIDER=auto
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
LLM_MAX_TOKENS=3000

# MiniMax-M3 only: "adaptive" keeps model thinking on; "disabled" skips it.
# Other providers use prompt-level internal reasoning and ignore this variable.
LLM_THINKING=adaptive

# ── Host port ────────────────────────────────────────────────────────────────
# The container always listens on 5173 internally; this is the port published
# on the host. Change it if 5173 is already taken.
APP_PORT=5173
