# Copy this file to .env and fill in the values:  cp .env.example .env
#
# ── Recognition mode ─────────────────────────────────────────────────────────
# Default is local detector mode: no LLM call, no API key needed. It uses the
# Python mahjong-detector package inside the container.
RECOGNITION_MODE=detector

# Optional LLM fallback mode. Set RECOGNITION_MODE=llm to use this instead.
# The backend calls an OpenAI-compatible vision endpoint, so it works with any
# provider that speaks that API. Set the base URL, the API key, and a
# vision-capable model id for your provider of choice:
#
#   Kimi (Moonshot)   LLM_BASE_URL=https://api.moonshot.ai/v1     (or .cn in China)
#                     LLM_MODEL=moonshot-v1-32k-vision-preview     (or kimi-k2.5)
#   MiniMax           LLM_BASE_URL=https://api.minimax.io/v1
#                     LLM_MODEL=MiniMax-M3
#   OpenAI            LLM_BASE_URL=https://api.openai.com/v1        (or leave blank)
#                     LLM_MODEL=gpt-4o
#   Claude            LLM_BASE_URL=https://api.anthropic.com/v1/
#                     LLM_MODEL=claude-opus-4-8
#
# Leave LLM_BASE_URL blank to use OpenAI's default endpoint.
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# ── Host port ────────────────────────────────────────────────────────────────
# The container always listens on 5173 internally; this is the port published
# on the host. Change it if 5173 is already taken.
APP_PORT=5173
