# Copy this file to .env and fill in the values:  cp .env.example .env
#
# Roboflow Hosted YOLO inference. The API key stays server-side.
ROBOFLOW_API_KEY=

# Default detector for this branch:
# https://universe.roboflow.com/wen-wu-mn6q9/mj-detection/model/4
ROBOFLOW_BASE_URL=https://serverless.roboflow.com
ROBOFLOW_MODEL=mj-detection/4

# Output-label adapter. "auto" uses wen-wu-37 for mj-detection/* and direct
# mpsz-label parsing for models such as mahjong-9xjry/1.
ROBOFLOW_MODEL_PRESET=auto

# Optional override when a model's numeric classes do not match the preset.
# Accepts either JSON or comma pairs, for example:
# ROBOFLOW_CLASS_MAP={"0":"1m","1":"2m"}
# ROBOFLOW_CLASS_MAP=0:1m,1:2m,34:0m
ROBOFLOW_CLASS_MAP=

# Detection tuning. Lower confidence returns more boxes; higher confidence
# returns fewer boxes. Overlap is Roboflow's same-class NMS setting.
ROBOFLOW_CONFIDENCE=30
ROBOFLOW_OVERLAP=30

# Extra server-side de-duplication across all classes. Raise it if real tiles
# disappear, lower it if duplicate boxes produce extra tiles.
ROBOFLOW_DEDUP_IOU=0.55

# Host port published by Docker Compose. The container listens on 5173.
APP_PORT=5173
